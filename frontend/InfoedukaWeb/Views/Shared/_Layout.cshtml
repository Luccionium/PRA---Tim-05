<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Infoeduka</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="ie-navbar">
        <div class="container ie-navbar__container">
            <a class="ie-navbar__brand" asp-controller="Kolegij" asp-action="Index">
                <span class="ie-navbar__brand-ie">Info</span><span class="ie-navbar__brand-eduka">eduka</span>
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                var _ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                <div class="ie-navbar__links">
                    <a class="ie-navbar__link @(_ctrl == "Kolegij" ? "active" : "")" asp-controller="Kolegij" asp-action="Index">Kolegiji</a>
                    <a class="ie-navbar__link @(_ctrl == "Obavijest" ? "active" : "")" asp-controller="Obavijest" asp-action="Index">Obavijesti</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="ie-navbar__link @(_ctrl == "Korisnik" ? "active" : "")" asp-controller="Korisnik" asp-action="Index">Predavači</a>
                    }
                </div>
                <div class="ie-navbar__right">
                    <span class="ie-navbar__user">@User.Identity.Name</span>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="ie-btn-logout">Odjava</button>
                    </form>
                </div>
            }
        </div>
    </nav>
    <div class="ie-main">
        <div class="container py-4">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>
    @if (TempData["Toast"] is string toastMsg)
    {
        <div id="ie-toast" class="ie-toast">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ie-toast__icon"><polyline points="20 6 9 17 4 12"/></svg>
            @toastMsg
        </div>
        <script>setTimeout(function(){var t=document.getElementById('ie-toast');if(t)t.classList.add('ie-toast--hide');},3000);</script>
    }
    @if (TempData["Error"] is string errMsg)
    {
        <div id="ie-toast-err" class="ie-toast ie-toast--error">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ie-toast__icon"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            @errMsg
        </div>
        <script>setTimeout(function(){var t=document.getElementById('ie-toast-err');if(t)t.classList.add('ie-toast--hide');},5000);</script>
    }
    <div class="modal fade" id="ie-confirm-modal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered" style="max-width:360px">
        <div class="modal-content">
          <div class="modal-body px-4 pt-4 pb-2">
            <p id="ie-confirm-text" class="mb-0" style="font-size:.95rem"></p>
          </div>
          <div class="modal-footer border-0 px-4 pb-4 gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Odustani</button>
            <button type="button" class="btn btn-danger btn-sm" id="ie-confirm-ok">Obriši</button>
          </div>
        </div>
      </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      (function () {
        var pending = null;
        document.addEventListener('submit', function (e) {
          var msg = e.target.getAttribute('data-confirm');
          if (!msg) return;
          e.preventDefault();
          pending = e.target;
          document.getElementById('ie-confirm-text').textContent = msg;
          new bootstrap.Modal(document.getElementById('ie-confirm-modal')).show();
        }, true);
        document.getElementById('ie-confirm-ok').addEventListener('click', function () {
          bootstrap.Modal.getInstance(document.getElementById('ie-confirm-modal')).hide();
          if (pending) { pending.removeAttribute('data-confirm'); pending.requestSubmit(); pending = null; }
        });
      })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
