@model InfoedukaWeb.Models.LoginViewModel
@{ ViewData["Title"] = "Prijava"; Layout = null; }

<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prijava - Infoeduka</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center" style="min-height:100vh">
        <div class="card shadow-sm" style="width:380px">
            <div class="card-body p-4">
                <h4 class="card-title mb-4 text-center">Infoeduka</h4>
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" type="email" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Lozinka" class="form-label">Lozinka</label>
                        <input asp-for="Lozinka" class="form-control" type="password" autocomplete="current-password" />
                        <span asp-validation-for="Lozinka" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Prijava</button>
                </form>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
