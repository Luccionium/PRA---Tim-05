@model InfoedukaWeb.Models.ObavijestFormViewModel
@{ ViewData["Title"] = "Nova obavijest"; }

<div class="ie-page-header">
    <h2>Nova obavijest</h2>
    @if (Model.ReturnKolegijId.HasValue)
    {
        <a asp-controller="Kolegij" asp-action="Details" asp-route-id="@Model.ReturnKolegijId" class="btn btn-outline-secondary">Natrag</a>
    }
    else
    {
        <a asp-action="Index" class="btn btn-outline-secondary">Natrag</a>
    }
</div>

<div class="ie-form-card">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="ReturnKolegijId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Naziv" class="form-label">Naziv</label>
                <input asp-for="Naziv" class="form-control" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Opis" class="form-label">Opis</label>
                <textarea asp-for="Opis" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="KolegijId" class="form-label">Kolegij</label>
                <select asp-for="KolegijId" class="form-select"
                        asp-items="@(new SelectList(Model.Kolegiji, "Id", "Naziv"))">
                    <option value="0">-- Odaberite kolegij --</option>
                </select>
                <span asp-validation-for="KolegijId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DatumObjave" class="form-label">Datum objave</label>
                <input asp-for="DatumObjave" class="form-control" type="date"
                       value="@Model.DatumObjave.ToString("yyyy-MM-dd")" />
            </div>
            <div class="mb-3">
                <label asp-for="DatumIsteka" class="form-label">Datum isteka</label>
                <input asp-for="DatumIsteka" class="form-control" type="date"
                       value="@Model.DatumIsteka.ToString("yyyy-MM-dd")" />
            </div>
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Odustani</a>
        </form>
</div>
