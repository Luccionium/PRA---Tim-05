@model List<InfoedukaWeb.Models.ObavijestViewModel>
@{ ViewData["Title"] = "Obavijesti"; }

<div class="ie-page-header">
    <h2>Obavijesti</h2>
    <a asp-action="Create" class="btn btn-primary">Nova obavijest</a>
</div>

@if (!Model.Any())
{
    <div class="ie-empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <p>Nema obavijesti.</p>
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Naziv</th>
                <th>Kolegij</th>
                <th>Datum objave</th>
                <th>Datum isteka</th>
                <th>Kreator</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model.OrderByDescending(o => o.DatumObjave))
            {
                <tr>
                    <td>@o.Naziv</td>
                    <td>@o.KolegijNaziv</td>
                    <td>@o.DatumObjave.ToString("dd.MM.yyyy")</td>
                    <td>
                        @o.DatumIsteka.ToString("dd.MM.yyyy")
                        <span class="ie-badge @(o.DatumIsteka.Date < DateTime.Today ? "ie-badge-expired" : "ie-badge-active") ms-1">
                            @(o.DatumIsteka.Date < DateTime.Today ? "Istekla" : "Aktivna")
                        </span>
                    </td>
                    <td>@o.KreatorIme</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">Uredi</a>
                        <form asp-action="Delete" asp-route-id="@o.Id" method="post" class="d-inline ms-1"
                              data-confirm="Obrisati obavijest @o.Naziv?">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Obriši</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
