@model InfoedukaWeb.Models.KorisnikFormViewModel
@{ ViewData["Title"] = "Dodaj korisnika"; }

<div class="ie-page-header">
    <h2>Dodaj korisnika</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Natrag</a>
</div>

<div class="ie-form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Ime" class="form-label">Ime</label>
                <input asp-for="Ime" class="form-control" />
                <span asp-validation-for="Ime" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Prezime" class="form-label">Prezime</label>
                <input asp-for="Prezime" class="form-control" />
                <span asp-validation-for="Prezime" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Lozinka" class="form-label">Lozinka</label>
                <input asp-for="Lozinka" class="form-control" type="password" />
                <span asp-validation-for="Lozinka" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Tip" class="form-label">Tip</label>
                <select asp-for="Tip" class="form-select">
                    <option value="Predavac">Predavač</option>
                    <option value="Admin">Administrator</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Spremi</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Odustani</a>
        </form>
</div>
